# ═══════════════════════════════════════
# EST Website — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════

# Payload CMS (REQUIRED — generate with: openssl rand -base64 32)
PAYLOAD_SECRET=

# PostgreSQL credentials (REQUIRED)
POSTGRES_USER=est
POSTGRES_PASSWORD=
POSTGRES_DB=est_db

# Database connection (REQUIRED — built from POSTGRES_* vars for Docker)
DATABASE_URI=postgresql://est:YOUR_PASSWORD_HERE@db:5432/est_db

# Node environment
NODE_ENV=production

# Site URL
NEXT_PUBLIC_SITE_URL=https://est.egat.co.th

# Stack verification rails (optional)
STACK_VERIFY_BASE_URL=
STACK_VERIFY_ENABLE_MUTATION=0
STACK_VERIFY_TEST_PLATFORM=ios
STACK_VERIFY_TEST_REGION=th

# Analytics (optional)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# reCAPTCHA (optional — for registration spam protection)
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
