// Eternal Tower Saga — Database Schema
// Tech: SQLite via Prisma ORM (optimized for 100 concurrent users)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Pre-Registration System
// ─────────────────────────────────────────────

model Registration {
  id           String   @id @default(cuid())
  email        String   @unique
  platform     String   // "ios" | "android" | "pc"
  region       String   // "th" | "sea" | "global"
  referralCode String   @unique // unique code for this user to share
  referredBy   String?  // referralCode of the person who invited them
  ipAddress    String?  // for rate-limiting & anti-fraud
  userAgent    String?  // device info
  locale       String   @default("th") // language preference at registration
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Referral relationships
  referrer     Registration?  @relation("Referrals", fields: [referredBy], references: [referralCode])
  referrals    Registration[] @relation("Referrals")

  @@index([referredBy])
  @@index([createdAt])
  @@index([platform])
  @@index([region])
}

// ─────────────────────────────────────────────
// Milestone Rewards (managed via Payload CMS)
// ─────────────────────────────────────────────

model Milestone {
  id          Int     @id @default(autoincrement())
  threshold   Int     @unique  // e.g. 10000, 25000, 50000...
  titleTh     String           // Thai title
  titleEn     String           // English title
  rewards     String           // JSON: [{ "item": "Gold", "qty": 200000, "icon": "/images/gold.png" }]
  isUnlocked  Boolean @default(false)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// ─────────────────────────────────────────────
// News & Updates (managed via Payload CMS)
// ─────────────────────────────────────────────

model News {
  id          String   @id @default(cuid())
  titleTh     String           // Thai title
  titleEn     String           // English title
  contentTh   String           // Thai content (rich text / markdown)
  contentEn   String           // English content
  category    String           // "update" | "event" | "maintenance" | "patch"
  thumbnail   String           // URL/path to thumbnail image
  slug        String   @unique // URL-friendly identifier
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([slug])
}

// ─────────────────────────────────────────────
// Event Configuration
// ─────────────────────────────────────────────

model EventConfig {
  id          String   @id @default(cuid())
  eventKey    String   @unique  // "pre_registration_2026"
  titleTh     String
  titleEn     String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  settings    String   @default("{}") // JSON: additional config (OG tags, share text, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Game Characters (for Character Gallery)
// ─────────────────────────────────────────────

model GameCharacter {
  id          String   @id @default(cuid())
  nameTh      String
  nameEn      String
  classTh     String           // "นักดาบ" / "Swordsman"
  classEn     String
  faction     String           // "light" | "dark" | "nature" | "fire" | "water"
  rarity      String           // "legendary" | "epic" | "rare"
  descTh      String           // Thai lore/description
  descEn      String           // English lore/description
  portraitUrl String           // Full character portrait
  iconUrl     String           // Small circular icon
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([faction])
  @@index([sortOrder])
}

// ─────────────────────────────────────────────
// Rate Limiting / Anti-Abuse Log
// ─────────────────────────────────────────────

model RateLimitLog {
  id        Int      @id @default(autoincrement())
  ipAddress String
  endpoint  String
  count     Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([ipAddress, endpoint, windowStart])
  @@index([ipAddress, endpoint])
}

// ─────────────────────────────────────────────
// Analytics Events (lightweight tracking)
// ─────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   // "page_view" | "register_click" | "share_click" | "store_click"
  eventData String   @default("{}") // JSON: { "platform": "ios", "source": "referral" }
  ipAddress String?
  userAgent String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId])
}
